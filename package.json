{
  "name": "micugl",
  "version": "0.0.16",
  "description": "Micu gl - Small React shader library",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    },
    "./devtools": {
      "types": "./dist/react/devtools/index.d.ts",
      "import": "./dist/devtools.mjs",
      "require": "./dist/devtools.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "vite build && node scripts/assertTreeshaken.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "bench": "playwright test --project=counters",
    "bench:timing": "playwright test --project=timing"
  },
  "peerDependencies": {
    "mp4-muxer": "^5.2.2",
    "react": "^18.0.0 || ^19.0.0 || ^19.1.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "webm-muxer": "^5.1.4"
  },
  "peerDependenciesMeta": {
    "mp4-muxer": {
      "optional": true
    },
    "webm-muxer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8",
    "eslint": "^9.25.0",
    "eslint-plugin-react-dom": "^1.48.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-react-x": "^1.48.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "mp4-muxer": "^5.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^4.1.10",
    "webm-muxer": "^5.1.4"
  }
}
